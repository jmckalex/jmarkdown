Cell[BoxData[
 RowBox[{
  RowBox[{"handleMessage", "[", "source_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rawData", "=", 
      RowBox[{"source", "[", "\"\<Data\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Parse", " ", "POST", " ", "data"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"bodyStart", "=", 
      RowBox[{"StringPosition", "[", 
       RowBox[{"rawData", ",", "\"\<\\r\\n\\r\\n\>\""}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "bodyStart", "]"}], ">", "0"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"body", "=", 
         RowBox[{"StringDrop", "[", 
          RowBox[{"rawData", ",", 
           RowBox[{"bodyStart", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"pairs", "=", 
         RowBox[{"StringSplit", "[", 
          RowBox[{"body", ",", "\"\<&\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"keyValuePairs", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"StringSplit", "[", 
            RowBox[{"#", ",", "\"\<=\>\"", ",", "2"}], "]"}], "&"}], "/@", 
          "pairs"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"msg", "=", 
         RowBox[{"Association", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "->", 
             RowBox[{"URLDecode", "[", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "&"}], "/@", 
           "keyValuePairs"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Get", " ", "the", " ", "code", " ", "to", " ", "evaluate", " ", 
          "it"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"mathematicaCode", "=", 
         RowBox[{"msg", "[", "\"\<message\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"returnFormat", "=", 
         RowBox[{"msg", "[", "\"\<returnAs\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"\"\<Evaluating: \>\"", ",", "mathematicaCode"}], "]"}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Evaluate", " ", "the", " ", "code"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"result", "=", 
         RowBox[{"Check", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"ToExpression", "[", "mathematicaCode", "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Print", "[", "\"\<Evaluation error!\>\"", "]"}], ";", 
            "$Failed"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"result", "=!=", "$Failed"}], ",", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Generate", " ", "output", " ", "in", " ", "requested", " ", 
            "format"}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"output", "=", 
            RowBox[{"Switch", "[", 
             RowBox[{
             "returnFormat", ",", "\[IndentingNewLine]", "\"\<svg\>\"", ",", 
              RowBox[{
               RowBox[{"Export", "[", 
                RowBox[{"\"\<~/output.svg\>\"", ",", "result"}], "]"}], ";", 
               RowBox[{"Export", "[", 
                RowBox[{"\"\<~/output.txt\>\"", ",", 
                 RowBox[{"ExportString", "[", 
                  RowBox[{"result", ",", "\"\<SVG\>\""}], "]"}]}], "]"}], ";", 
               RowBox[{"ExportString", "[", 
                RowBox[{"result", ",", "\"\<SVG\>\""}], "]"}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{"\"\<svg\>\"", ",", 
                RowBox[{"ExportString", "[", 
                 RowBox[{"result", ",", "\"\<SVG\>\""}], "]"}], ","}], "*)"}],
               "\[IndentingNewLine]", "\"\<png\>\"", ",", 
              RowBox[{"BaseEncode", "[", 
               RowBox[{"ExportByteArray", "[", 
                RowBox[{"result", ",", "\"\<PNG\>\""}], "]"}], "]"}], ",", 
              "\[IndentingNewLine]", "_", ",", 
              RowBox[{"ToString", "[", "result", "]"}]}], 
             "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{"Determine", " ", "content", " ", "type"}], "*)"}], 
           "\[IndentingNewLine]", 
           RowBox[{"contentType", "=", 
            RowBox[{"Switch", "[", 
             RowBox[{
             "returnFormat", ",", "\[IndentingNewLine]", "\"\<svg\>\"", 
              ",", "\"\<image/svg+xml\>\"", ",", 
              "\[IndentingNewLine]", "\"\<png\>\"", ",", "\"\<image/png\>\"", 
              ",", "\[IndentingNewLine]", "_", ",", "\"\<text/plain\>\""}], 
             "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{"Send", " ", "HTTP", " ", "response"}], "*)"}], 
           "\[IndentingNewLine]", 
           RowBox[{"httpResponse", "=", 
            RowBox[{"StringJoin", "[", "\[IndentingNewLine]", 
             
             RowBox[{"\"\<HTTP/1.1 200 OK\\r\\n\>\"", ",", 
              "\[IndentingNewLine]", "\"\<Content-Type: \>\"", ",", 
              "contentType", ",", "\"\<\\r\\n\>\"", ",", 
              "\[IndentingNewLine]", "\"\<Content-Length: \>\"", ",", 
              RowBox[{"ToString", "[", 
               RowBox[{"StringLength", "[", "output", "]"}], "]"}], 
              ",", "\"\<\\r\\n\>\"", 
              ",", "\"\<Access-Control-Allow-Origin: *\\r\\n\>\"", ",", 
              "\[IndentingNewLine]", "\"\<Access-Control-Allow-Methods: POST, \
GET, OPTIONS\\r\\n\>\"", 
              ",", "\"\<Access-Control-Allow-Headers: Content-Type\\r\\n\>\"",
               ",", "\"\<\\r\\n\>\"", ",", "\[IndentingNewLine]", "output"}], 
             "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
            "Write", " ", "response", " ", "back", " ", "to", " ", "the", " ",
              "client"}], "*)"}], "\[IndentingNewLine]", 
           RowBox[{"WriteString", "[", 
            RowBox[{
             RowBox[{"source", "[", "\"\<SourceSocket\>\"", "]"}], ",", 
             "httpResponse"}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Print", "[", 
            RowBox[{"\"\<Response sent, length: \>\"", ",", 
             RowBox[{"StringLength", "[", "output", "]"}]}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Error", " ", "case", " ", "of", " ", "IF", " ", "statement"}], 
           "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"errorResponse", "=", 
            RowBox[{"StringJoin", "[", "\[IndentingNewLine]", 
             
             RowBox[{"\"\<HTTP/1.1 500 Internal Server Error\\r\\n\>\"", ",", 
              "\[IndentingNewLine]", "\"\<Content-Type: text/plain\\r\\n\>\"",
               ",", "\[IndentingNewLine]", "\"\<Access-Control-Allow-Origin: \
*\\r\\n\>\"", ",", "\[IndentingNewLine]", "\"\<\\r\\n\>\"", ",", 
              "\[IndentingNewLine]", "\"\<Error evaluating Mathematica code\>\
\""}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"WriteString", "[", 
            RowBox[{
             RowBox[{"source", "[", "\"\<SourceSocket\>\"", "]"}], ",", 
             "errorResponse"}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Print", "[", "\"\<Error response sent\>\"", "]"}]}]}], 
         "]"}]}]}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.957178323946918*^9, 3.957178363095861*^9}, {
  3.957178536792986*^9, 3.95717855343895*^9}, {3.9571785860092707`*^9, 
